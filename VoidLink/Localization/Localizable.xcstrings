    "pointerVelocityDividerStackTip" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensitivity divider line: used to separate the pass-through zone from the adjustment zone for touch-point movement speed in multi-touch games (e.g. Genshin Impact, Honkai: Star Rail). For details, see the online documentation."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "灵敏度分割线, 用于划分多点触控游戏(原神/崩坏星穹铁道)中触点移速的透传区域和调整区域. 详见在线文档."
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "靈敏度分割線：用於在多點觸控遊戲（例如《原神》、《崩壞：星穹鐵道》）中分隔觸控點移動速度的傳遞區和調整區。詳情請參閱線上文件。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "靈敏度分割線：用於在多點觸控遊戲（例如《原神》、《崩壞：星穹鐵道》）中分隔觸控點移動速度的傳遞區和調整區。詳情請參閱線上文件。"
          }
        }
      }
    },
