    "Custom Resolution Selected" : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已设定为自定义分辨率"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已選取自訂解析度"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已選取自訂解析度"
          }
        }
      }
    },
    "Custom resolutions are not officially supported by GeForce Experience, so it will not set your host display resolution. You will need to set it manually while in game.\n\nResolutions that are not supported by your client or host PC may cause streaming errors." : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可能需要在主机端的显卡控制面板手动添加自定义分辨率"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GeForce Experience 未正式支援自訂解析度，因此不會設定您的主機顯示解析度。您需要在遊戲中手動設定。\n\n您的用戶端或主機電腦不支援的解析度可能會導致串流錯誤。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
