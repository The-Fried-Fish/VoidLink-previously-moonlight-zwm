        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "陀螺仪切换按键: %@\n陀螺仪保持按键: %@\n\n以上按键被启用后，也可用于启动/暂停DS4陀螺仪映射"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "陀螺儀切換按鍵: %@\n陀螺儀保持按鍵: %@\n\n以上按鍵啟用後，也可用於啟動／暫停 DS4 陀螺儀映射。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "陀螺儀切換按鍵: %@\n陀螺儀保持按鍵: %@\n\n以上按鍵啟用後，也可用於啟動／暫停 DS4 陀螺儀映射。"
          }
        }
      }
    },
    "controllerMouseExpoStackTip" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The larger this value is, the flatter the curve becomes near the zero point (center). When set to 1, it is completely linear."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "该值越大，接近零点(中心点)的曲线越平缓。为 1 时则为完全线性。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "該值越大，接近零點（中心點）的曲線越平緩。為 1 時則為完全線性。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "該值越大，接近零點（中心點）的曲線越平緩。為 1 時則為完全線性。"
          }
        }
      }
    },
