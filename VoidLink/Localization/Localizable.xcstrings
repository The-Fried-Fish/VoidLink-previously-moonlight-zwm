    "asyncFrameDequeueStackTip" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- Disabled: may improve visual smoothness\n- Enabled: may improve control input responsiveness"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "- 关闭：或改善画面连贯性\n- 开启：或改善控制输入响应延迟"
